<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Glassmorphism Card style -->
    <style name="GlassCardStyle">
        <item name="android:background">@drawable/bg_glass_card</item>
        <item name="android:padding">16dp</item>
    </style>

    <!-- Neon Puzzle Tile style -->
    <style name="PuzzleTileStyle" parent="Widget.Material3.Button.ElevatedButton">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:padding">2dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/medic_accent</item>
        <item name="backgroundTint">@color/medic_surface</item>
        <item name="shapeAppearanceOverlay">@style/RoundedButton</item>
        <item name="strokeColor">@color/medic_accent</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="GameButtonStyle" parent="Widget.Material3.Button">
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="shapeAppearanceOverlay">@style/CapsuleButton</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">#020617</item> <!-- Dark text on bright button -->
        <item name="backgroundTint">@color/medic_accent</item>
    </style>

    <style name="CapsuleButton" parent="">
        <item name="cornerSize">30dp</item>
    </style>

    <style name="RoundedButton" parent="">
        <item name="cornerSize">16dp</item>
    </style>

    <!-- Neon Input Style -->
    <style name="GameInputStyle" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxStrokeColor">@color/medic_accent</item>
        <item name="boxCornerRadiusBottomEnd">16dp</item>
        <item name="boxCornerRadiusBottomStart">16dp</item>
        <item name="boxCornerRadiusTopEnd">16dp</item>
        <item name="boxCornerRadiusTopStart">16dp</item>
        <item name="hintTextColor">@color/medic_accent</item>
        <item name="android:textColorHint">@color/medic_accent</item>
        <item name="boxBackgroundColor">@color/medic_surface</item>
    </style>
</resources>
