<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/game_background"
    android:padding="24dp">

    <TextView
        android:id="@+id/stageTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="LEVEL 1: EPIDERMIS"
        android:textColor="@color/layer_epidermis"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/missionText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MISSION: SHIELD THE SURFACE"
        android:textColor="@color/game_text"
        android:textSize="12sp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/stageTitle" />

    <ProgressBar
        android:id="@+id/barrierHealth"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="20dp"
        android:layout_marginTop="16dp"
        android:progress="100"
        android:progressTint="#4CAF50"
        app:layout_constraintTop_toBottomOf="@id/missionText" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="BARRIER INTEGRITY"
        android:textColor="#FFFFFF"
        android:textSize="10sp"
        app:layout_constraintEnd_toEndOf="@id/barrierHealth"
        app:layout_constraintTop_toBottomOf="@id/barrierHealth" />

    <!-- Game Area Placeholder -->
    <FrameLayout
        android:id="@+id/gameArea"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:layout_marginBottom="24dp"
        android:background="#11FFFFFF"
        app:layout_constraintBottom_toTopOf="@id/btnComplete"
        app:layout_constraintTop_toBottomOf="@id/barrierHealth">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:text="[TAP THE UV RAYS &amp; GERMS]"
            android:textColor="@color/layer_epidermis"
            android:alpha="0.5"/>
            
        <!-- Floating icons would be added programmatically in a real game -->
        <Button
            android:id="@+id/dummyTarget"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_gravity="top|center"
            android:layout_marginTop="40dp"
            android:text="🦠"
            android:background="?android:attr/selectableItemBackground"
            android:textSize="30sp"/>

    </FrameLayout>

    <Button
        android:id="@+id/btnComplete"
        style="@style/GameButtonStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ANALYZE RESULTS"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
