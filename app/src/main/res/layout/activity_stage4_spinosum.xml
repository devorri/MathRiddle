<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/medic_bg"
    android:padding="24dp"
    tools:context=".Stage4Activity">

    <TextView
        android:id="@+id/stageTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="STAGE 4"
        android:textColor="@color/layer_epidermis"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/missionTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="STRATUM SPINOSUM"
        android:textColor="@color/medic_text"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/instructionText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="DEFENSE INITIATED: TAP THE VIRAL AGENTS TO NEUTRALIZE"
        android:textColor="@color/medic_secondary"
        android:textSize="12sp"
        android:textStyle="bold" />

    <!-- Infection Defense Area -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="400dp"
        android:layout_marginTop="32dp"
        app:cardCornerRadius="32dp"
        app:cardBackgroundColor="@color/medic_surface">

        <FrameLayout
            android:id="@+id/infectionZone"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:padding="24dp" />
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/infectionStatusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="NEUTRALIZED: 0/15"
        android:textColor="@color/medic_text"
        android:textSize="18sp"
        android:textStyle="bold" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <Button
        android:id="@+id/btnComplete"
        style="@style/GameButtonStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="REINFORCE BASE"
        android:visibility="gone" />

</LinearLayout>
