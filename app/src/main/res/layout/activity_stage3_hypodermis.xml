<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/medic_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal"
        tools:context=".Stage7Activity">

        <TextView
            android:id="@+id/stageTitle3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="STAGE 7"
            android:textColor="@color/layer_hypodermis"
            android:textSize="14sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="THE HYPODERMIS"
            android:textColor="@color/medic_text"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="MISSION: THERMAL INSULATION &amp; STORAGE"
            android:textColor="@color/medic_secondary"
            android:textSize="12sp"
            android:textStyle="bold" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="40dp"
            app:cardBackgroundColor="@color/medic_surface">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center"
                android:padding="24dp">

                <TextView
                    android:id="@+id/timerText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TIME: 60s"
                    android:textColor="#FF3366"
                    android:textSize="28sp"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/bossCharacter"
                    android:layout_width="150dp"
                    android:layout_height="150dp"
                    android:src="@drawable/ic_boss"
                    android:layout_marginTop="16dp" />

                <TextView
                    android:id="@+id/targetWord"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="READY?"
                    android:textColor="#00FFCC"
                    android:textSize="32sp"
                    android:textStyle="bold"
                    android:layout_marginTop="8dp" />

                <TextView
                    android:id="@+id/bossStatus"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PATHOGEN OVERLORD: ACTIVE"
                    android:textColor="@color/layer_hypodermis"
                    android:textSize="14sp"
                    android:layout_marginTop="4dp" />

                <LinearLayout
                    android:id="@+id/bossSpellingSlots"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:orientation="horizontal" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:id="@+id/bossProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="WORDS DEFEATED: 0/10"
            android:textColor="@color/medic_text"
            android:textSize="18sp"
            android:textStyle="bold" />

        <GridLayout
            android:id="@+id/bossKeyboard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:columnCount="6"
            android:layout_gravity="center_horizontal" />

        <Button
            android:id="@+id/btnComplete3"
            style="@style/GameButtonStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="16dp"
            android:text="CORE PROTECTED: FINISH"
            android:visibility="gone" />

    </LinearLayout>
</ScrollView>
