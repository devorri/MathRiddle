<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- ====== TOP NAV BAR ====== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_gradient_header"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="8dp"
            android:paddingEnd="8dp">

            <Button
                android:id="@+id/navHome"
                style="@style/NavButtonActiveStyle"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:text="🏠"
                android:layout_margin="4dp" />

            <Button
                android:id="@+id/navLeaderboard"
                style="@style/NavButtonStyle"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:text="🏆"
                android:layout_margin="4dp" />

            <Button
                android:id="@+id/navProfile"
                style="@style/NavButtonStyle"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:text="👤"
                android:layout_margin="4dp" />

            <Button
                android:id="@+id/navSettings"
                style="@style/NavButtonStyle"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:text="⚙️"
                android:layout_margin="4dp" />
        </LinearLayout>

        <!-- ====== WELCOME SECTION ====== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingTop="24dp"
            android:paddingBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="✨ Welcome to Math Riddles Pro"
                android:textColor="@color/primary"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Challenge your mind and improve your skills!"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />
        </LinearLayout>

        <!-- ====== STATS ROW ====== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="16dp">

            <!-- Total Solved -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_stat_card"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp"
                android:layout_marginEnd="6dp">

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_stat_icon"
                    android:gravity="center"
                    android:text="🏅"
                    android:textSize="18sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Solved"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/statTotalSolved"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Best Streak -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_stat_card"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp">

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_stat_icon"
                    android:gravity="center"
                    android:text="📈"
                    android:textSize="18sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Best Streak"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/statBestStreak"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textColor="@color/primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>

            <!-- Accuracy -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:background="@drawable/bg_stat_card"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="14dp"
                android:layout_marginStart="6dp">

                <TextView
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:background="@drawable/bg_stat_icon"
                    android:gravity="center"
                    android:text="🎯"
                    android:textSize="18sp" />

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginStart="10dp">
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Accuracy"
                        android:textColor="@color/text_secondary"
                        android:textSize="11sp" />
                    <TextView
                        android:id="@+id/statAccuracy"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0%"
                        android:textColor="@color/primary"
                        android:textSize="20sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ====== CHOOSE A CATEGORY ====== -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:layout_marginBottom="12dp"
            android:text="Choose a Category"
            android:textColor="@color/text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Category Grid: 2x2 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp">

            <!-- Row 1: Arithmetic + Logic -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="10dp">

                <!-- Arithmetic card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    android:background="@drawable/bg_category_card"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🔢"
                            android:textSize="28sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_stat_icon"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="2dp"
                            android:paddingBottom="2dp"
                            android:text="Category"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Arithmetic"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Test your arithmetic skills"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">
                        <TextView
                            android:id="@+id/chipArithEasy"
                            style="@style/DifficultyChipEasy"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="easy"
                            android:layout_marginEnd="4dp" />
                        <TextView
                            android:id="@+id/chipArithMedium"
                            style="@style/DifficultyChipMedium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="medium"
                            android:layout_marginEnd="4dp" />
                        <TextView
                            android:id="@+id/chipArithHard"
                            style="@style/DifficultyChipHard"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="hard" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnStartArithmetic"
                        style="@style/OrangeButtonStyle"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="10dp"
                        android:text="Start Challenge" />
                </LinearLayout>

                <!-- Logic card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp"
                    android:background="@drawable/bg_category_card"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="✖️"
                            android:textSize="28sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_stat_icon"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="2dp"
                            android:paddingBottom="2dp"
                            android:text="Category"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Logic"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Test your logic skills"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">
                        <TextView
                            android:id="@+id/chipLogicEasy"
                            style="@style/DifficultyChipEasy"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="easy"
                            android:layout_marginEnd="4dp" />
                        <TextView
                            android:id="@+id/chipLogicMedium"
                            style="@style/DifficultyChipMedium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="medium"
                            android:layout_marginEnd="4dp" />
                        <TextView
                            android:id="@+id/chipLogicHard"
                            style="@style/DifficultyChipHard"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="hard" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnStartLogic"
                        style="@style/OrangeButtonStyle"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="10dp"
                        android:text="Start Challenge" />
                </LinearLayout>
            </LinearLayout>

            <!-- Row 2: Patterns + Word Problems -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <!-- Patterns card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="5dp"
                    android:background="@drawable/bg_category_card"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="🔄"
                            android:textSize="28sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_stat_icon"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="2dp"
                            android:paddingBottom="2dp"
                            android:text="Category"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Patterns"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Test your patterns skills"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">
                        <TextView
                            android:id="@+id/chipPatternEasy"
                            style="@style/DifficultyChipEasy"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="easy"
                            android:layout_marginEnd="4dp" />
                        <TextView
                            android:id="@+id/chipPatternMedium"
                            style="@style/DifficultyChipMedium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="medium"
                            android:layout_marginEnd="4dp" />
                        <TextView
                            android:id="@+id/chipPatternHard"
                            style="@style/DifficultyChipHard"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="hard" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnStartPatterns"
                        style="@style/OrangeButtonStyle"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="10dp"
                        android:text="Start Challenge" />
                </LinearLayout>

                <!-- Word Problems card -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="5dp"
                    android:background="@drawable/bg_category_card"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">
                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="📝"
                            android:textSize="28sp" />
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@drawable/bg_stat_icon"
                            android:paddingStart="8dp"
                            android:paddingEnd="8dp"
                            android:paddingTop="2dp"
                            android:paddingBottom="2dp"
                            android:text="Category"
                            android:textColor="@color/text_secondary"
                            android:textSize="10sp" />
                    </LinearLayout>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Word Problems"
                        android:textColor="@color/text_primary"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Test your word skills"
                        android:textColor="@color/text_secondary"
                        android:textSize="12sp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginTop="8dp">
                        <TextView
                            android:id="@+id/chipWordEasy"
                            style="@style/DifficultyChipEasy"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="easy"
                            android:layout_marginEnd="4dp" />
                        <TextView
                            android:id="@+id/chipWordMedium"
                            style="@style/DifficultyChipMedium"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="medium"
                            android:layout_marginEnd="4dp" />
                        <TextView
                            android:id="@+id/chipWordHard"
                            style="@style/DifficultyChipHard"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="hard" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/btnStartWord"
                        style="@style/OrangeButtonStyle"
                        android:layout_width="match_parent"
                        android:layout_height="40dp"
                        android:layout_marginTop="10dp"
                        android:text="Start Challenge" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- ====== RANDOM CHALLENGE ====== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_random_challenge"
            android:orientation="vertical"
            android:padding="24dp"
            android:layout_marginStart="16dp"
            android:layout_marginEnd="16dp"
            android:layout_marginBottom="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Random Challenge"
                android:textColor="#FFFFFF"
                android:textSize="22sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Try all riddles in random order"
                android:textColor="#CCDDFF"
                android:textSize="14sp" />

            <Button
                android:id="@+id/btnRandomChallenge"
                android:layout_width="wrap_content"
                android:layout_height="44dp"
                android:layout_marginTop="12dp"
                android:background="@drawable/bg_orange_button"
                android:text="Start Random Challenge"
                android:textColor="#FFFFFF"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:paddingStart="20dp"
                android:paddingEnd="20dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>