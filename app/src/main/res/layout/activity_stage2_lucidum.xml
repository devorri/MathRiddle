<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/medic_bg"
    android:padding="24dp"
    tools:context=".Stage2Activity">

    <TextView
        android:id="@+id/stageTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="STAGE 2"
        android:textColor="@color/layer_epidermis"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/missionTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="STRATUM LUCIDUM"
        android:textColor="@color/medic_text"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/instructionText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="ALIGN THE PRISMS TO CONDUCT THE BEAM: 0°, 90°, 180°"
        android:textColor="@color/neon_cyan"
        android:textSize="12sp"
        android:textStyle="bold" />

    <!-- Trivia Question Area -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        app:cardCornerRadius="32dp"
        app:cardBackgroundColor="@color/medic_surface">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/questionText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Where is the Stratum Lucidum primarily found in the human body?"
                android:textColor="@color/medic_text"
                android:textSize="18sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="24dp" />

            <Button
                android:id="@+id/option1"
                style="@style/GameButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:text="On the Face and Neck"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/option2"
                style="@style/GameButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:text="Only on the Palms and Soles"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/option3"
                style="@style/GameButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:text="Protecting the Elbows"
                android:textAllCaps="false" />

            <Button
                android:id="@+id/option4"
                style="@style/GameButtonStyle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="4dp"
                android:text="In the Scalp Region"
                android:textAllCaps="false" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <TextView
        android:id="@+id/lucidityText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="BEAM STATUS: DISCONNECTED"
        android:textColor="@color/medic_text"
        android:textSize="18sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/btnComplete"
        style="@style/GameButtonStyle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:text="CONTINUE DESCENT"
        android:visibility="gone" />

</LinearLayout>
